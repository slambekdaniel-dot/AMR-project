// ---------------- MOTORS ----------------
#define L1 13
#define L2 27
#define L3 12
#define L4 14

#define R1 4
#define R2 0
#define R3 4
#define R4 0

// ---------------- SENSORS ----------------
#define TRIG_FRONT 32
#define ECHO_FRONT 35
#define TRIG_RIGHT 25
#define ECHO_RIGHT 33
#define TRIG_LEFT 16
#define ECHO_LEFT 17

// ---------------- GRID ----------------
#define GRID_SIZE 50
int grid[GRID_SIZE][GRID_SIZE];

int gx = GRID_SIZE / 2;
int gy = GRID_SIZE / 2;

// ---------------- ROS ----------------
rcl_node_t node;
rclc_support_t support;
rcl_allocator_t allocator;

rcl_publisher_t scan_pub;
rcl_publisher_t odom_pub;
rcl_publisher_t tf_pub;

sensor_msgs__msg__LaserScan scan_msg;
nav_msgs__msg__Odometry odom_msg;
tf2_msgs__msg__TFMessage tf_msg;
geometry_msgs__msg__TransformStamped transform;

// ---------------- ROBOT STATE ----------------
float posX = 0;
float posY = 0;
float theta = 0;

int sensorPhase = 0;
float l = 0, f = 0, r = 0;

// ---------------- CONTROL ----------------
int speedMotor = 140;
int speedMotorLeft = 120;
int speedMotorRight = 110;
int stepTime = 920;
int turnTime = 400;
int turnSpeedRight = 210;
int turnSpeedLeft = 230;

int escape_steps = 0;

bool robotMoving = false;

// ---------------- UTILS ----------------
float normalizeAngle(float a) {
  while (a > M_PI) a -= 2*M_PI;
  while (a < -M_PI) a += 2*M_PI;
  return a;
}

void snapToGrid() {
  float step = M_PI / 2;
  theta = round(theta / step) * step;
  theta = normalizeAngle(theta);
}

// ---------------- DISTANCE ----------------
float getDistance(int trig, int echo) {
  digitalWrite(trig, LOW);
  delayMicroseconds(2);
  digitalWrite(trig, HIGH);
  delayMicroseconds(10);
  digitalWrite(trig, LOW);

  long duration = pulseIn(echo, HIGH, 12000);  // ~2 meters max
  if (duration == 0) return 999;

  float d = duration * 0.034 / 2;
  if (d < 2 || d > 300) return 999;

  return d;
}



// ---------------- GRID ----------------
int dirX(float angle) { return round(cos(angle)); }
int dirY(float angle) { return round(sin(angle)); }

bool visited(int x, int y) {
  if (x < 0 || x >= GRID_SIZE || y < 0 || y >= GRID_SIZE) return true;
  return grid[x][y] == 1;
}

void markVisited() {
  grid[gx][gy] = 1;
}

void getFrontCell(int &x, int &y) {
  x = gx + dirX(theta);
  y = gy + dirY(theta);
}

void getLeftCell(int &x, int &y) {
  x = gx + dirX(theta - M_PI_2);
  y = gy + dirY(theta - M_PI_2);
}

void getRightCell(int &x, int &y) {
  x = gx + dirX(theta + M_PI_2);
  y = gy + dirY(theta + M_PI_2);
}

// ---------------- MOTORS ----------------
void stopMotors() {
  analogWrite(L1, 0); analogWrite(L2, 0);
  analogWrite(L3, 0); analogWrite(L4, 0);
  analogWrite(R1, 0); analogWrite(R2, 0);
  analogWrite(R3, 0); analogWrite(R4, 0);
}

void brakeMotors() {
  analogWrite(L1, 120);
  analogWrite(L3, 120);
  analogWrite(R1, 120);
  analogWrite(R3, 120);
  delay(40);
  stopMotors();
}

// ---------------- SAFE FORWARD ----------------
void forwardStepSafe() {

  robotMoving = true;

  float f = getDistance(TRIG_FRONT, ECHO_FRONT) / 100.0;
  if (f < 0.25) {
    robotMoving = false;
    return;
  }

  analogWrite(L2, speedMotorLeft);
  analogWrite(L4, speedMotorLeft);
  analogWrite(R2, speedMotorRight);
  analogWrite(R4, speedMotorRight);

  unsigned long start = millis();

  while (millis() - start < stepTime) {

    float f_live = getDistance(TRIG_FRONT, ECHO_FRONT) / 100.0;

    if (f_live < 0.07) {
      brakeMotors();
      robotMoving = false;
      return;
    }
  }

  brakeMotors();

  float step = 0.30; // REAL DISTANCE

  posX += step * cos(theta);
  posY += step * sin(theta);

  gx += dirX(theta);
  gy += dirY(theta);

  markVisited();

  robotMoving = false;
}

// ---------------- TURNS ----------------
void turnRight() {

  robotMoving = true;

  analogWrite(L1, turnSpeedRight);
  analogWrite(L3, turnSpeedRight);
  analogWrite(R2, turnSpeedRight);
  analogWrite(R4, turnSpeedRight);

  delay(turnTime);

  stopMotors();

   theta += 1.5708;

  snapToGrid();

  robotMoving = false;
}

void turnLeft() {

  robotMoving = true;

  analogWrite(L2, turnSpeedLeft);
  analogWrite(L4, turnSpeedLeft);
  analogWrite(R1, turnSpeedLeft);
  analogWrite(R3, turnSpeedLeft);

  delay(turnTime);
  stopMotors();

   theta -= 1.5708;

  snapToGrid();

  robotMoving = false;
}

