// ---------------- LOOP ----------------
void loop() {

  uint32_t ms = millis();
  int32_t sec = ms / 1000;
  uint32_t nanosec = (ms % 1000) * 1000000;

  float l = getDistance(TRIG_LEFT, ECHO_LEFT) / 100.0;
  delay(25);
  
  float f = getDistance(TRIG_FRONT, ECHO_FRONT) / 100.0;
  delay(25);
  
  float r = getDistance(TRIG_RIGHT, ECHO_RIGHT) / 100.0;
  delay(25);

  float WALL = 0.21;
 

  bool left_free  = l > WALL;
  bool front_free = f > WALL;
  bool right_free = r > WALL;


  int fx, fy, lx, ly, rx, ry;
  
  getFrontCell(fx, fy);
  getLeftCell(lx, ly);
  getRightCell(rx, ry);
  
  if (front_free && !visited(fx, fy)) {
    forwardStepSafe();
  }
  else if (left_free && !visited(lx, ly)) {
    turnLeft();
  }
  else if (right_free && !visited(rx, ry)) {
    turnRight();
  }
  else if (front_free) {
    forwardStepSafe();
  }
  else if (left_free) {
    turnLeft();
  }
  else if (right_free) {
    turnRight();
  }
  else {
    turnRight();
    turnRight();
    delay(100);
    escape_steps = 2;
  }

  // -------- PUBLISH --------
 // -------- TF --------
  transform.header.stamp.sec = sec;
  transform.header.stamp.nanosec = nanosec;
  
  transform.header.frame_id.data = (char*)"odom";
  transform.header.frame_id.size = strlen("odom");
  transform.header.frame_id.capacity = 10;
  
  transform.child_frame_id.data = (char*)"base_link";
  transform.child_frame_id.size = strlen("base_link");
  transform.child_frame_id.capacity = 20;
  
  transform.transform.translation.x = posX;
  transform.transform.translation.y = posY;
  transform.transform.translation.z = 0;
  
  transform.transform.rotation.x = 0;
  transform.transform.rotation.y = 0;
  transform.transform.rotation.z = sin(theta/2);
  transform.transform.rotation.w = cos(theta/2);

  scan_msg.header.stamp.sec = sec;
  scan_msg.header.stamp.nanosec = nanosec;

  if (!robotMoving) {
  
    scan_msg.ranges.data[0] = l;
    scan_msg.ranges.data[1] = f;
    scan_msg.ranges.data[2] = r;
  
    rcl_publish(&scan_pub, &scan_msg, NULL);
  }

    // -------- ODOM --------
  odom_msg.header.stamp.sec = sec;
  odom_msg.header.stamp.nanosec = nanosec;
  
  odom_msg.header.frame_id.data = (char*)"odom";
  odom_msg.child_frame_id.data = (char*)"base_link";
  
  odom_msg.pose.pose.position.x = posX;
  odom_msg.pose.pose.position.y = posY;
  
  odom_msg.pose.pose.orientation.x = 0;
  odom_msg.pose.pose.orientation.y = 0;
  odom_msg.pose.pose.orientation.z = sin(theta/2);
  odom_msg.pose.pose.orientation.w = cos(theta/2);
  
//  odom_msg.pose.covariance[0] = 0.01;
//  odom_msg.pose.covariance[7] = 0.01;
//  odom_msg.pose.covariance[35] = 0.05;

  rcl_publish(&tf_pub, &tf_msg, NULL);
  rcl_publish(&odom_pub, &odom_msg, NULL);
}
